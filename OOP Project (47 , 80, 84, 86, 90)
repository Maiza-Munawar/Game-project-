//  BASE CLASS: Game

class Game {
protected:
    int score;
    int difficulty;
public:
    Game(int d) : score(0), difficulty(d) {}
    virtual int play() = 0;   // Pure virtual - har game apna khud implement karega
    virtual ~Game() {}
    int getScore() { return score; }
};


//  CLASS: WordScramble

class WordScramble : public Game {
public:
    WordScramble(int d) : Game(d) {}

    int play() override {
        cout << "\n**********************\n";
        cout << "* WORD SCRAMBLE GAME *\n";
        cout << "**********************\n";

        string words[3][5] = {
            {"evolution","array","skeleton","credit","learn"},
            {"account","customer","beautiful","asteroid","difficult"},
            {"consultant","mysterical","habitually","phenomena","compensate"}
        };
        string scrambled[3][5] = {
            {"volutioen","rayar","tonsklee","cterdi","nlear"},
            {"cnacuot","ecmstoru","utabueifl","taserodi","ffidulcit"},
            {"suctanlont","tyrsiemacl","bauthllaiy","menaohpen","pomacesten"}
        };

        int d = difficulty - 1;
        if(d < 0 || d > 2) { cout << "Invalid difficulty!\n"; return 0; }

        string answer;
        for(int i = 0; i < 5; i++) {
            cout << "\nUnscramble: " << scrambled[d][i] << "\nYour answer: ";
            cin >> answer;
            if(answer == words[d][i]) { cout << "Correct!\n"; score++; }
            else cout << "Wrong! Answer was: " << words[d][i] << "\n";
        }

        cout << "Score: " << score << "/5\n";
        score = (score * 10) / 5;
        return score;
    }
};


